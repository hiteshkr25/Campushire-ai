FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/campushire

# Email (password reset)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@campushire.ai
MAIL_SUPPRESS_SEND=true

# Auth
PASSWORD_RESET_TOKEN_MAX_AGE=3600
BCRYPT_LOG_ROUNDS=12

# Optional — for external reset links in production
# SERVER_NAME=campushire.example.com
# PREFERRED_URL_SCHEME=https
